{
  "name": "proj-track",
  "version": "1.0.0",
  "description": "Track CLI command history per-project with zero terminal interference",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "proj-track": "dist/index.js",
    "proj-track-logger": "dist/logger.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "cli",
    "command-history",
    "project-tracker",
    "terminal",
    "developer-tools"
  ],
  "author": "Ali Raza",
  "license": "MIT",
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "files": [
    "dist",
    "src/hooks"
  ],
  "engines": {
    "node": ">=18.0.0"
  }
}
